# Base de données PostgreSQL (Prisma). Sajel compte b7al Vercel Postgres, Neon,
# wla Supabase (kolhom 3andhom free tier), o coller l connection string hna.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Secret bach nextauth ysayfti l JWT (khass tbedlo f production)
# Dir wa7ed random string: openssl rand -base64 32
AUTH_SECRET=change-me-in-production

# Stripe (paiement b carte) — bach ykhdem "Carte bancaire" f checkout
# Sajel compte f https://dashboard.stripe.com/register o khod l clé secrète (test mode l bidaya)
STRIPE_SECRET_KEY=sk_test_xxx

# IMPORTANT: URL kaml dyal site (production, mnقل https://). Kaystعmel f Stripe redirect,
# o f SEO (sitemap.xml, robots.txt, canonical URLs, Open Graph). Khass tbeddlha l vrai domaine
# mnin deployiti, wa la khass tb9a localhost.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NOTE IMPORTANTE: Stripe machi disponible bach t7el compte marchand men Maroc mباشرة.
# Ila l client 3ndo entité/compte f bled feha Stripe disponible (France, USA, UK...) khdama mzyan.
# Ila la, bdel l intégration l CMI, PayZone, wla PayTabs (PSPs maghariba) — nafs pattern
# (créer session/payment intent server-side, redirect, verify on return) ykhdem m3a a7sen mnhom.
